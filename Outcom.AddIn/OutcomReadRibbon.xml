<?xml version="1.0" encoding="utf-8"?>
<customUI xmlns="http://schemas.microsoft.com/office/2009/07/customui"
          onLoad="Ribbon_Load">
  <ribbon>
    <tabs>
      <tab idMso="TabReadMessage">
        <group id="outcomReadAssistedRepliesGroup"
               label="Outcom"
               autoScale="true">
          <button id="outcomReadReplyAndProposeButton"
                  label="Répondre et proposer"
                  imageMso="Reply"
                  size="large"
                  screentip="Répondre et proposer une réponse"
                  supertip="Créer une réponse à ce courrier, ouvrir son brouillon et lancer immédiatement une proposition Codex en arrière-plan."
                  onAction="ReplyAndPropose" />
          <button id="outcomReadReplyAllAndProposeButton"
                  label="Répondre à tous et proposer"
                  imageMso="ReplyAll"
                  size="large"
                  screentip="Répondre à tous et proposer une réponse"
                  supertip="Créer une réponse à tous à ce courrier, ouvrir son brouillon et lancer immédiatement une proposition Codex en arrière-plan."
                  onAction="ReplyAllAndPropose" />
          <box id="outcomReadActivityCountersBox" boxStyle="vertical">
            <labelControl id="outcomReadActiveOperationsLabel"
                          getLabel="GetActiveOperationsLabel" />
            <labelControl id="outcomReadCompletedOperationsLabel"
                          getLabel="GetCompletedOperationsLabel" />
          </box>
        </group>
      </tab>
    </tabs>
  </ribbon>
</customUI>
